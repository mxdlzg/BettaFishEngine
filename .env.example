# =====================================================================
#                    BETTAFISH 舆情分析系统配置文件
# =====================================================================
# 使用说明：
# 1. 复制本文件为 .env
# 2. 根据您的实际环境填写配置
# 3. 必填项标记为 [必填]，可选项标记为 [可选]
# =====================================================================

# ====================== 服务配置 ======================
# BettaFish Web服务地址
HOST=0.0.0.0
PORT=5000

# ====================== 数据库配置（可选） ======================
# 如果不需要数据库功能可以留空
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CHARSET=utf8mb4
DB_DIALECT=postgresql

# =====================================================================
#                          LLM 模型配置
# =====================================================================
# 说明：系统支持OpenAI兼容格式的API，可以使用以下任一服务：
# - GPUStack本地部署
# - OpenAI官方API
# - 第三方中转服务（如aihubmix.com）
# - 各厂商官方API（DeepSeek、Moonshot、通义千问等）

# ==================== 统一LLM服务配置 [推荐] ====================
# 如果所有Agent使用同一个LLM服务，只需配置以下三项
# [必填] LLM API密钥
LLM_API_KEY=your_api_key_here

# [必填] LLM服务地址（OpenAI兼容格式）
LLM_API_BASE=http://your-llm-server:port/v1

# [可选] 模型名称（留空则自动获取第一个可用模型）
LLM_API_MODEL=

# ==================== 分引擎LLM配置（高级） ====================
# 如果不同引擎需要使用不同的模型，可以分别配置
# 留空则自动使用上面的统一配置

# Query引擎（负责搜索查询和初步分析）
QUERY_ENGINE_API_KEY=
QUERY_ENGINE_BASE_URL=
QUERY_ENGINE_MODEL_NAME=

# Media引擎（负责媒体内容分析）
MEDIA_ENGINE_API_KEY=
MEDIA_ENGINE_BASE_URL=
MEDIA_ENGINE_MODEL_NAME=

# Insight引擎（负责深度洞察和情感分析）
INSIGHT_ENGINE_API_KEY=
INSIGHT_ENGINE_BASE_URL=
INSIGHT_ENGINE_MODEL_NAME=

# Report引擎（负责最终报告生成，建议使用较强模型）
REPORT_ENGINE_API_KEY=
REPORT_ENGINE_BASE_URL=
REPORT_ENGINE_MODEL_NAME=

# MindSpider引擎（负责知识图谱构建）
MINDSPIDER_API_KEY=
MINDSPIDER_BASE_URL=
MINDSPIDER_MODEL_NAME=

# 论坛主持人（负责多Agent协调）
FORUM_HOST_API_KEY=
FORUM_HOST_BASE_URL=
FORUM_HOST_MODEL_NAME=

# SQL关键词优化器
KEYWORD_OPTIMIZER_API_KEY=
KEYWORD_OPTIMIZER_BASE_URL=
KEYWORD_OPTIMIZER_MODEL_NAME=

# =====================================================================
#                         搜索工具配置
# =====================================================================

# ==================== 搜索工具选择 ====================
# 支持的搜索工具类型：
# - duckduckgo: 免费，无需API密钥（推荐初次使用）
# - AnspireAPI: 付费，性价比高
# - BochaAPI: 付费，多模态搜索
# - tavily: 付费，专业搜索
SEARCH_TOOL_TYPE=duckduckgo

# ==================== Tavily搜索（可选） ====================
# 申请地址：https://www.tavily.com/
TAVILY_API_KEY=

# ==================== Anspire搜索（可选） ====================
# 申请地址：https://open.anspire.cn/
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=

# ==================== Bocha搜索（可选） ====================
# 申请地址：https://open.bochaai.com/
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
BOCHA_WEB_SEARCH_API_KEY=

# =====================================================================
#                         MCP知识库配置
# =====================================================================
# MCP知识库用于连接外部知识源，提供更丰富的背景信息

# [可选] MCP服务地址
ALB_MCP_URL=

# [可选] MCP访问令牌
ALB_MCP_TOKEN=

# =====================================================================
#                         输出配置
# =====================================================================

# 报告输出目录
OUTPUT_DIR=./outputs

# 是否保存中间状态（调试用）
SAVE_INTERMEDIATE_STATES=true

# 公开报告访问地址（用于生成分享链接）
PUBLIC_REPORT_BASE_URL=

# =====================================================================
#                         高级配置
# =====================================================================

# 调试模式（0=关闭, 1=开启）
DEBUG=0

# 请求超时时间（秒）
REQUEST_TIMEOUT_SEC=120

# 最大重试次数
MAX_RETRIES=3

# 搜索相关配置
MAX_SEARCH_RESULTS_FOR_LLM=50
MAX_REFLECTIONS=3
MAX_PARAGRAPHS=6
SEARCH_TIMEOUT=240
MAX_CONTENT_LENGTH=500000

# =====================================================================
#                         配置示例
# =====================================================================
# 
# 示例1：使用本地GPUStack部署（推荐用于内部部署）
# LLM_API_KEY=gpustack_xxxxx
# LLM_API_BASE=http://192.168.1.100:18011/v1
# LLM_API_MODEL=your_model_name
# SEARCH_TOOL_TYPE=duckduckgo
#
# 示例2：使用DeepSeek官方API
# LLM_API_KEY=sk-xxxxx
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_MODEL=deepseek-chat
# SEARCH_TOOL_TYPE=duckduckgo
#
# 示例3：使用OpenAI官方API
# LLM_API_KEY=sk-xxxxx
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_MODEL=gpt-4o
# SEARCH_TOOL_TYPE=tavily
# TAVILY_API_KEY=tvly-xxxxx
#
# =====================================================================